rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Onsen catalog — read-only for any authenticated user
    // Writes go through the data repo service account, never the app
    match /onsens/{kyuhachiId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Catalog metadata — read-only for any authenticated user
    match /catalog_meta/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Challenge type definitions — read-only for any authenticated user
    match /challenge_types/{typeId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Area guides (tourist info per region): read-only for any authenticated user.
    // Writes go through the data repo service account, never the app.
    match /area_guides/{areaId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Area-guides metadata (publish version): read-only for any authenticated user.
    match /area_guides_meta/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // User documents and all subcollections — owner only
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // earnedTier (the claimed tier) and earnedTierAt (when it was claimed) are
      // server-only, written exclusively by the claimTier callable (admin
      // credentials bypass rules). The client may create them as null and may
      // never change them, so a tier can't be forged.
      match /challenges/{challengeId} {
        allow read, delete: if isOwner(userId);
        allow create: if isOwner(userId)
          && (!('earnedTier' in request.resource.data) || request.resource.data.earnedTier == null)
          && (!('earnedTierAt' in request.resource.data) || request.resource.data.earnedTierAt == null);
        allow update: if isOwner(userId)
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['earnedTier', 'earnedTierAt']);

        match /visits/{onsenId} {
          allow read, write: if isOwner(userId);
        }
      }

      match /routes/{routeId} {
        allow read, write: if isOwner(userId);
      }

      match /favorites/{onsenId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
