# Kyuhachi iOS delivery — build the app and upload it to TestFlight (internal).
#
# This runs on a GitHub Actions macOS runner (see .github/workflows/deploy.yml),
# NOT in Expo's cloud. The native `ios/` project is regenerated by `expo
# prebuild` on every run and is gitignored, so every path below is relative to
# the freshly prebuilt project and nothing here is committed.
#
# Single environment: one `beta` lane that builds + uploads to TestFlight
# internal testers. No staging/production split, no App Store submission.
#
# Credentials arrive as files the workflow writes from base64 GitHub secrets
# (the same pattern the repo already uses for GoogleService-Info):
#   ENV["IOS_DIST_CERT_P12_PATH"]   Apple Distribution certificate (.p12)
#   ENV["IOS_CERTIFICATE_PASSWORD"] the .p12 export password
#   ENV["ASC_API_KEY_PATH"]         App Store Connect API key JSON
#                                   ({ key_id, issuer_id, key, in_house })

require "securerandom"

APP_ID     = "com.kyuhachi.app".freeze
TEAM_ID    = "L357YP9W28".freeze
WORKSPACE  = "ios/Kyuhachi.xcworkspace".freeze
XCODEPROJ  = "ios/Kyuhachi.xcodeproj".freeze
SCHEME     = "Kyuhachi".freeze
INFO_PLIST = "ios/Kyuhachi/Info.plist".freeze
IPA_NAME   = "Kyuhachi.ipa".freeze

# App Store Connect's TestFlight ingestion intermittently returns a transient
# 5xx on the final "complete upload" call *after* the binary is delivered, and
# re-runs can hit ITMS-90189 (redundant binary). Retry transient errors; treat
# an already-present build as success so re-runs are idempotent. Mirrors the
# proven wrapper from the Kiroku app.
def upload_to_testflight_with_retry(api_key_path)
  attempts = 0
  max_attempts = 3
  begin
    attempts += 1
    upload_to_testflight(
      api_key_path: api_key_path,
      distribute_external: false,
      skip_waiting_for_build_processing: true,
      ipa: IPA_NAME,
    )
  rescue => e
    message = e.message.to_s
    if message.match?(/already been used|already exists|already been uploaded|redundant binary/i)
      UI.important("Build already present on App Store Connect; treating the TestFlight upload as successful (#{message.strip})")
    elsif attempts < max_attempts && message.match?(%r{status code 5\d\d|internal server error|CHANGE UPLOAD STATE TO COMPLETE|Could not download/upload|Error uploading ipa|timed out|connection reset}i)
      UI.error("TestFlight upload attempt #{attempts}/#{max_attempts} failed: #{message.strip}")
      UI.important("Retrying in 30s after a transient App Store Connect error...")
      sleep(30)
      retry
    else
      raise
    end
  end
end

default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight (internal)"
  lane :beta do
    asc_api_key_path = ENV.fetch("ASC_API_KEY_PATH")

    keychain_name     = "kyuhachi-build.keychain"
    keychain_password = SecureRandom.base64

    create_keychain(
      name: keychain_name,
      password: keychain_password,
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      add_to_search_list: true,
    )

    begin
      import_certificate(
        certificate_path: ENV.fetch("IOS_DIST_CERT_P12_PATH"),
        certificate_password: ENV.fetch("IOS_CERTIFICATE_PASSWORD"),
        keychain_name: keychain_name,
        keychain_password: keychain_password,
      )

      # Generate/download a fresh App Store provisioning profile from the ASC
      # API key — no long-lived .mobileprovision to store or renew. Requires the
      # key to have App Manager (or Admin) role. If the key is Developer-only,
      # store the profile as a base64 secret instead and replace this block with:
      #   install_provisioning_profile(path: ENV.fetch("IOS_PROFILE_PATH"))
      #   profile_name = "<the profile's name>"
      get_provisioning_profile(
        api_key_path: asc_api_key_path,
        app_identifier: APP_ID,
        force: true,
      )
      profile_name = ENV.fetch("sigh_#{APP_ID}_appstore_profile-name")

      # Build number from TestFlight, scoped to the current marketing version.
      # Expo SDK 55 writes CFBundleVersion as a literal in Info.plist (not a
      # $(CURRENT_PROJECT_VERSION) reference), so we set it directly there — that
      # literal is what ends up in the .ipa. A failed/non-uploading run leaves the
      # TestFlight max unchanged, so the next run reuses latest+1: no drift.
      version = get_info_plist_value(path: INFO_PLIST, key: "CFBundleShortVersionString")
      latest = latest_testflight_build_number(
        api_key_path: asc_api_key_path,
        app_identifier: APP_ID,
        version: version,
        initial_build_number: 0,
      )
      set_info_plist_value(path: INFO_PLIST, key: "CFBundleVersion", value: (latest.to_i + 1).to_s)

      # Pin manual signing to the generated profile so the archive is
      # deterministic on a fresh runner (Expo prebuild defaults to automatic).
      # Scoped to the app target so it can't touch other targets' settings.
      update_code_signing_settings(
        use_automatic_signing: false,
        path: XCODEPROJ,
        targets: [SCHEME],
        team_id: TEAM_ID,
        code_sign_identity: "Apple Distribution",
        profile_name: profile_name,
      )

      build_app(
        workspace: WORKSPACE,
        scheme: SCHEME,
        output_name: IPA_NAME,
        export_method: "app-store",
        export_options: {
          provisioningProfiles: { APP_ID => profile_name },
          manageAppVersionAndBuildNumber: false,
        },
        xcargs: "-allowProvisioningUpdates",
      )

      upload_to_testflight_with_retry(asc_api_key_path)
    ensure
      keychain_db = File.expand_path("~/Library/Keychains/#{keychain_name}-db")
      delete_keychain(name: keychain_name) if File.exist?(keychain_db)
    end
  end
end
