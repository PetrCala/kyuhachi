{
	"cli": {
		"version": ">= 16.0.0",
		"appVersionSource": "remote"
	},
	"build": {
		"development": {
			"developmentClient": true,
			"distribution": "internal",
			"env": {
				"EXPO_PUBLIC_ENABLE_DEV_TOOLS": "true"
			},
			"ios": {
				"simulator": false,
				"resourceClass": "m-medium"
			}
		},
		"preview": {
			"distribution": "internal",
			"env": {
				"EXPO_PUBLIC_ENABLE_DEV_TOOLS": "true"
			},
			"ios": {
				"resourceClass": "m-medium",
				"autoIncrement": true
			}
		},
		"production": {
			"distribution": "store",
			"ios": {
				"resourceClass": "m-medium",
				"autoIncrement": true
			}
		}
	},
	"submit": {
		"production": {
			"ios": {
				"appleTeamId": "L357YP9W28",
				"ascAppId": "6761064476"
			}
		}
	}
}
